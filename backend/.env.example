# ============================================================================
# SimuCast environment variables
# ============================================================================
# Copy this file to .env (same folder) and fill in real values.
# .env is gitignored so your secrets never get committed.
#
#   cp .env.example .env
#
# ============================================================================

# --- Flask config ---
# A random long string. Flask uses this to sign session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Debug mode — True during development (shows errors, auto-reloads).
# ALWAYS set to False in production.
FLASK_DEBUG=True

# Set to "production" on Render so secure cross-site cookies are enabled.
# FLASK_ENV=production

# Allowed CORS origin(s) for the frontend. Comma-separated for multiple.
# Local dev defaults to http://localhost:5173 if unset.
# In production set this to your Render static-site URL, e.g.
#   FRONTEND_ORIGIN=https://simucast.onrender.com
# FRONTEND_ORIGIN=http://localhost:5173

# --- Database ---
# For development we use SQLite (a single file, no server needed).
# In production set DATABASE_URL to a Postgres URL. Render's managed
# Postgres provides this automatically via the render.yaml blueprint.
#   postgresql://user:pass@host:5432/simucast
DATABASE_URL=sqlite:///simucast.db

# --- AI ---
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Upload limits ---
# Maximum file size in megabytes. 50MB is plenty for student datasets.
MAX_UPLOAD_MB=50
