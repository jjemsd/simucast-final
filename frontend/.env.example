# No secrets on the frontend. The only thing here is the backend URL.
#
# Local dev: leave VITE_API_URL empty so requests go through Vite's
#            /api proxy (configured in vite.config.js).
# Production (Render): set this at build time to your backend service URL,
#            e.g. VITE_API_URL=https://simucast-api.onrender.com
VITE_API_URL=
